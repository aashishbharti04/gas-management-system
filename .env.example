# ─────────────────────────────────────────────────────────────────────────────
# Gas Management System — example environment configuration
# Copy this file to `.env` and adjust. NEVER commit your real `.env`.
# All variables are optional; sensible defaults are used when unset.
# ─────────────────────────────────────────────────────────────────────────────

# ---- Storage backend: "sqlite" (default, zero-config) or "mysql" ----
GMS_DB_BACKEND=sqlite

# ---- SQLite (used when GMS_DB_BACKEND=sqlite) ----
GMS_SQLITE_PATH=gas_management.db

# ---- MySQL (used when GMS_DB_BACKEND=mysql) ----
# Requires: pip install gas-management-system[mysql]
GMS_MYSQL_HOST=localhost
GMS_MYSQL_PORT=3306
GMS_MYSQL_USER=root
GMS_MYSQL_PASSWORD=
GMS_MYSQL_DATABASE=gasin

# ---- Pricing (currency units per litre) ----
GMS_CNG_PRICE=75
GMS_LPG_PRICE=80
GMS_CURRENCY_SYMBOL=Rs.

# ---- Default administrator (seeded on first run only) ----
# Change these before first run for a secure deployment.
GMS_ADMIN_USERNAME=admin
GMS_ADMIN_PASSWORD=admin123

# ---- Web dashboard (optional FastAPI front-end) ----
# Requires: pip install gas-management-system[web]
GMS_WEB_HOST=127.0.0.1
GMS_WEB_PORT=8000
# Secret used to sign session cookies. Generate a strong value for production,
# e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
GMS_WEB_SECRET_KEY=
# Set to true when serving over HTTPS so cookies are marked Secure.
GMS_WEB_COOKIE_SECURE=false
